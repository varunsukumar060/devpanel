# devpanel .gitignore

# Python virtual environment
.venv/
venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Build / packaging artifacts
dist/
build/
*.egg-info/
*.egg
.eggs/

# Dev runner script (local only)
run.sh

# Distribution
*.whl
*.tar.gz

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# devpanel runtime data (stored in ~/.devpanel, not repo)
*.csv
*.log

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
